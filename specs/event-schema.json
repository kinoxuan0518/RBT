{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/rbt/event-schema.json",
  "title": "RBT Event",
  "type": "object",
  "required": [
    "event_type",
    "run_id",
    "mode",
    "status",
    "timestamp"
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "run_started",
        "stage_started",
        "stage_completed",
        "stage_failed",
        "run_completed",
        "run_failed",
        "run_stopped",
        "suggestion_generated"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "MORNING_RUN",
        "EVENING_RUN",
        "FULL_RUN",
        "STATUS_QUERY",
        "STOP",
        "RETRY_SYNC",
        "EVOLVE"
      ]
    },
    "stage": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "STARTED",
        "DONE",
        "FAILED",
        "SKIPPED",
        "STOPPED"
      ]
    },
    "note": {
      "type": "string"
    },
    "counts": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "human_intervention_required": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
