# RBT 环境变量配置
# 复制本文件为 config.env，填入真实值后执行：source config.env
# 不要将 config.env 提交到 git（已在 .gitignore 中排除）

# ── 飞书应用凭证 ──────────────────────────────────────────
# 在飞书开放平台 (open.feishu.cn) 创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 飞书多维表格 ──────────────────────────────────────────
# 打开多维表格，URL 中 /base/ 后面的字符串即为 APP_TOKEN
FEISHU_BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 各数据表的 Table ID（在多维表格设置中查看）
FEISHU_TABLE_CANDIDATE_MASTER=tblxxxxxxxxxxxxxxxx   # 候选人主档
FEISHU_TABLE_INTERACTION_LOG=tblxxxxxxxxxxxxxxxx    # 交互记录
FEISHU_TABLE_JOB_FUNNEL_DAILY=tblxxxxxxxxxxxxxxxx  # 每日漏斗统计

# ── 本地路径 ──────────────────────────────────────────────
# 缓存目录（存放职位规则、候选人记录等）
BOSSZHIBIN_CACHE_DIR=$HOME/.rbt/cache

# 简历下载目录
RESUME_DOWNLOAD_DIR=$HOME/Downloads/resumes

# ── 可选：Codex 用户专用 ──────────────────────────────────
# 如果你使用 Codex，skills 目录通常在 ~/.codex/skills
# 如果你使用 Claude Code 或其他工具，默认在 ~/.rbt/skills
# RBT_SKILLS_DIR=~/.codex/skills
